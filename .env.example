# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-v1-1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding Model
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# LLM Model
# LLM_MODEL=z-ai/glm-4.5-air:free
# LLM_MODEL=openai/gpt-oss-120b:free
LLM_MODEL=poolside/laguna-m.1:free


# ChromaDB Configuration
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000

# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8080

# Query Expansion (Stage 2) — when enabled, generates synonym queries on low-relevance results
# QUERY_EXPANSION_ENABLED=true
# QUERY_EXPANSION_COUNT=3

# Loose Prompt (Stage 3) — when enabled, relaxes system prompt to allow general knowledge answers
# LOOSE_PROMPT_ENABLED=true
